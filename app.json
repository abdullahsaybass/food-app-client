{
  "expo": {
    "name": "VFresh",
    "slug": "client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vfresh.png",
    "scheme": "vfresh",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vfresh.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/vfresh.png",
        "backgroundImage": "./assets/images/vfresh.png",
        "monochromeImage": "./assets/images/vfresh.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vfresh.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/vfresh.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/vfresh.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#1A1F2E",
          "dark": {
            "backgroundColor": "#1A1F2E"
          }
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow VFresh to use your location for delivery."
        }
      ],
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow VFresh to save invoices to your device.",
          "saveToPhotosPermission": "Allow VFresh to save invoices to your device.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3251de69-6545-4867-be66-3cd08922d0ce"
      },
      "googleAndroidClientId": "577480848489-clbuj99051f0tkcq507c33ptj2b8dg57.apps.googleusercontent.com",
      "googleWebClientId": "577480848489-b7b8f70vlj9qrf12pseibpeqa2p80o71.apps.googleusercontent.com"
    }
  }
}